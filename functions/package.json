{
  "name": "jinro-functions",
  "description": "人狼ゲーム Cloud Functions — サーバー権威(役職の秘匿・夜行動・投票の権威処理)",
  "type": "module",
  "main": "lib/index.mjs",
  "engines": { "node": "22" },
  "private": true,
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --format=esm --target=node22 --outfile=lib/index.mjs --external:firebase-admin --external:firebase-functions",
    "serve": "npm run build && firebase emulators:start --only functions,database,auth"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
